From 35d1339004a30ba0d67709d6090a718c337f29ca Mon Sep 17 00:00:00 2001
From: Kristian T <35293262+Ktusch@users.noreply.github.com>
Date: Thu, 18 Jun 2026 09:33:34 +0200
Subject: [PATCH] fix(run_agent): duck-type Mock check instead of importing
 unittest.mock

Replace isinstance(client, Mock) with hasattr(client, 'assert_called')
in run_agent.py (two locations), matching the same pattern as f01a72de6
for conversation_loop.py. Avoids ImportError when unittest.mock is not
available in ThreadPoolExecutor-dispatched cron job workers.
---
 run_agent.py | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/run_agent.py b/run_agent.py
index 331ff2c66..60a9c77b6 100644
--- a/run_agent.py
+++ b/run_agent.py
@@ -3489,9 +3489,9 @@ class AIAgent:
         Prior bug: getattr(client, "is_closed", False) returned the bound method,
         which is always truthy, causing unnecessary client recreation on every call.
         """
-        from unittest.mock import Mock
-
-        if isinstance(client, Mock):
+        # Use duck-typing instead of importing unittest.mock to
+        # avoid ImportError in ThreadPoolExecutor dispatch (cron jobs)
+        if hasattr(client, "assert_called"):
             return False
 
         is_closed_attr = getattr(client, "is_closed", None)
@@ -3639,10 +3639,10 @@ class AIAgent:
         return copilot_request_headers(is_agent_turn=True, is_vision=is_vision)
 
     def _create_request_openai_client(self, *, reason: str, api_kwargs: Optional[dict] = None) -> Any:
-        from unittest.mock import Mock
-
+        # Use duck-typing instead of importing unittest.mock to
+        # avoid ImportError in ThreadPoolExecutor dispatch (cron jobs)
         primary_client = self._ensure_primary_openai_client(reason=reason)
-        if isinstance(primary_client, Mock):
+        if hasattr(primary_client, "assert_called"):
             return primary_client
         with self._openai_client_lock():
             request_kwargs = dict(self._client_kwargs)
